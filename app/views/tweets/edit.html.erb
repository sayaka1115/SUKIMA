<%= form_for @tweet do |f| %>

<%# データ型がstringで自由記述の入力フォーム %>
  <div class="field">
    <%= f.label :タイトル %>
    <%= f.text_field :title, :size => 30 %>
  </div>

<%# データ型がstringで自由記述の入力フォーム %>
  <div class="field">
    <%= f.label :場所 %>
    <%= f.text_field :place, :size => "30x2" %>
  </div>

<div class="field">
  <%= f.label :"締切日時" %>
  <%= f.datetime_select :deadline %>
</div>

<div class="field">
  <%= f.label :開始時間 %>
  <%= f.datetime_select :start_time %>
</div>

<div class="field">
  <%= f.label :終了時間 %>
  <%= f.datetime_select :end_time %>
</div>

<%# データ型がtextで自由記述の入力フォーム %>
  <div class="field">
    <%= f.label :メモ  %>
    <%= f.text_area :memo, :size => "30x4" %>
  </div>

  <%= f.submit "投稿する" %>
<% end %>

<%= link_to "一覧に戻る", tweets_path %>
<h1><%= @date %> のスケジュール</h1>

<% (0..23).each do |hour| %>

  <div style="display:flex; border-bottom:1px solid #ccc; padding:10px;">

    <div style="width:100px;">
      <%= "%02d:00" % hour %>
    </div>

    <div>
      <% @blogs.each do |blog| %>

        <% if blog.start_time.hour == hour %>
          <div>
            <strong><%= blog.title %></strong>
            <p><%= blog.content %></p>
          </div>
        <% end %>

      <% end %>
    </div>

  </div>

<% end %>

<%= link_to "カレンダーに戻る", blogs_path %>